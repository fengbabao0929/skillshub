{
  "name": "wechat-auto-publisher",
  "version": "2.0.0",
  "description": "微信公众号爆款内容创作+自动发布器 - 从选题到发布的完整解决方案",
  "main": "scripts/content-creator.cjs",
  "scripts": {
    "config": "node scripts/wechat-config.cjs",
    "test": "node scripts/wechat-config.cjs --test",
    "publish": "node scripts/wechat-publisher.cjs",
    "publish:draft": "node scripts/wechat-publisher.cjs --action draft",
    "publish:now": "node scripts/wechat-publisher.cjs --action publish",
    "create": "node scripts/content-creator.cjs create",
    "titles": "node scripts/content-creator.cjs titles",
    "write": "node scripts/content-creator.cjs write"
  },
  "keywords": [
    "wechat",
    "weixin",
    "公众号",
    "爆款文章",
    "内容创作",
    "自动发布",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.3.0",
    "form-data": "^4.0.0",
    "inquirer": "^8.2.5",
    "marked": "^11.0.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
