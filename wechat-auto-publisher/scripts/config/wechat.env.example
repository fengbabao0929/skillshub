# 微信公众号开发者凭证
# 获取方式：公众号后台 -> 设置与开发 -> 基本配置
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# API基础URL
WECHAT_API_BASE=https://api.weixin.qq.com

# Token缓存时间（秒），默认7200秒，建议设置略小
TOKEN_EXPIRE_TIME=7000

# 图片上传配置
MAX_IMAGE_SIZE=2097152
SUPPORTED_IMAGE_FORMATS=jpg,png,gif

# 发布配置
DEFAULT_AUTHOR=默认作者名
